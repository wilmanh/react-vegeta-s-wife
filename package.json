{
  "name": "react-ui-vegetas-wife",
  "private": false,
  "version": "0.1.8",
  "type": "module",
  "description": "React UI component library built on top of Bulma.",
  "license": "MIT",
  "main": "./dist/react-vegetas-wife.cjs",
  "module": "./dist/react-vegetas-wife.js",
  "types": "./dist/index.d.ts",
  "author": {
    "name": "Sirius_Alpha",
    "email": "wilman.h.h@gmail.com",
    "url": "https://github.com/wilmanh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wilmanh/react-vegeta-s-wife.git"
  },
  "bugs": {
    "url": "https://github.com/wilmanh/react-vegeta-s-wife.git/issues"
  },
  "homepage": "https://github.com/wilmanh/react-vegeta-s-wife.git#readme",
  "keywords": [
    "react",
    "react-components",
    "ui",
    "component-library",
    "bulma",
    "bulma-css",
    "typescript",
    "vite",
    "storybook"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-vegetas-wife.js",
      "require": "./dist/react-vegetas-wife.cjs"
    },
    "./styles.css": "./dist/react-vegetas-wife.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "typecheck:storybook": "tsc -p tsconfig.storybook.json --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run lint && npm run test -- --run && npm run build"
  },
  "peerDependencies": {
    "bulma": "^1.0.4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "react-icons": "^5.5.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@eslint/js": "^9.35.0",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-onboarding": "10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "bulma": "^1.0.4",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "10.3.6",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "sass": "^1.92.1",
    "storybook": "10.3.6",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
